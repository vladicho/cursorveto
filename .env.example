# ── AWS Bedrock ──────────────────────────────────────────────────────────────────
# Região do Bedrock (mesma do EC2)
AWS_REGION=us-east-2

# Se o EC2 NÃO tiver IAM Role, preencha as credenciais abaixo:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Modelo Bedrock (padrão: anthropic.claude-sonnet-4-6-20250514-v1:0)
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20250514-v1:0

# ── WhatsApp Business API (Meta) ─────────────────────────────────────────────────
# Token de verificação — escolha qualquer string e use a mesma no painel Meta
WHATSAPP_VERIFY_TOKEN=moldelab_verify_2024

# Token de acesso permanente (System User Token do Meta Business)
WHATSAPP_ACCESS_TOKEN=

# ID do número de telefone no Meta Business (não é o número, é o ID da plataforma)
# Número: +5511981692038
WHATSAPP_PHONE_NUMBER_ID=

# Versão da Graph API (padrão: v21.0)
# WHATSAPP_GRAPH_API_VERSION=v21.0

# ── MoldeLab ─────────────────────────────────────────────────────────────────────
# Porta do servidor (padrão: 8787)
# PORT=8787

# Segredo JWT para autenticação de usuários
MOLDELAB_JWT_SECRET=

# Usuário admin inicial
MOLDELAB_BOOTSTRAP_EMAIL=
MOLDELAB_BOOTSTRAP_PASSWORD=

# Microserviço scikit-image (se houver)
# SKIMAGE_SERVICE_URL=
# SKIMAGE_SHARED_SECRET=
